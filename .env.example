# memos 后端地址
VITE_API_BASE=http://your-memos-server:5230

# ============================================================
# 日记功能配置（留空则前端菜单里不显示「日记」）
# 配置完后把本文件复制为 .env.local
# ============================================================

# GitHub Fine-grained PAT，需要对目标仓库开 Contents: Read and Write
VITE_GITHUB_TOKEN=

# 日记内容所在的仓库，格式：owner/repo
VITE_DIARY_REPO=olinll/Mizuki-Content

# 提交日记写入的分支
VITE_DIARY_BRANCH=master

# 日记数据文件在仓库中的路径（前端会解析这个 TS 文件）
VITE_DIARY_DATA_PATH=data/diary.ts

# 日记图片在仓库中的目录（上传 webp 时的写入位置）
VITE_DIARY_IMAGE_DIR=images/diary

# 图片 URL 前缀，会被拼进 data/diary.ts 里的 images 数组
# 例如：前缀 /images/diary + 文件名 foo.webp → /images/diary/foo.webp
VITE_DIARY_IMAGE_URL_PREFIX=/images/diary

# 博客入口（可选，仅用于列表页右上角的「查看博客」链接）
VITE_DIARY_BLOG_URL=https://blog.olinl.com/diary/
